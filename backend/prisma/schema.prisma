datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Alert {
  id         String   @id @default(uuid())
  txHash     String   @unique
  sender     String
  receiver   String
  amount     Float
  token      String
  riskScore  Int
  category   String   // Low Risk, Medium Risk, High Risk, Critical Risk
  protocol   String   // e.g. Navi, Cetus, Bucket, Scallop
  timestamp  DateTime @default(now())
  report     Report?
}

model Report {
  id            String @id @default(uuid())
  alertId       String @unique
  alert         Alert  @relation(fields: [alertId], references: [id], onDelete: Cascade)
  aiExplanation String
  confidence    Float  // e.g. 0.85
}

model Settings {
  id                 String  @id @default("system_settings")
  threshold          Int     @default(80)
  notificationType   String  @default("all") // all, critical, none
  largeTxThreshold   Float   @default(100000) // Large transaction rule threshold in USD
  liquidityDrainPct  Float   @default(20)     // Liquidity drain percentage
  newWalletAgeHours  Int     @default(24)     // New wallet threshold age in hours
  enableLargeTxRule  Boolean @default(true)
  enableDrainRule    Boolean @default(true)
  enableWalletRule   Boolean @default(true)
}
